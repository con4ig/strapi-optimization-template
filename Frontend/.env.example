# Frontend Environment Variables

# Internal URL used by the Next.js server running in Docker (must use Docker network 'strapi:1337')
STRAPI_INTERNAL_API_URL=http://strapi:1337

# Public URL used by the browser to fetch images/assets from Strapi (can be localhost)
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337

# The public base URL of the Next.js site (used for sitemap/metadata generation)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
